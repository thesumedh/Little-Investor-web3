<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= lesson.title %> — LittleInvestors</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" type="image/x-icon" href="/img/penny_logo.png">
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script src="/js/pendo-init.js"></script>
  <style>
    .lesson-progress-top{width:100%;background:#f1f5f9;height:4px;position:sticky;top:64px;z-index:40}
    .lesson-progress-fill{height:100%;background:linear-gradient(90deg,#2AA46A,#34d399);width:0%;transition:width 1s ease}
    .xp-flyout{position:fixed;top:80px;right:20px;background:#1a2332;color:#fff;border-radius:16px;padding:12px 18px;font-size:13px;font-weight:700;z-index:999;opacity:0;transform:translateY(-10px);transition:all .4s cubic-bezier(.34,1.56,.64,1);pointer-events:none}
    .xp-flyout.show{opacity:1;transform:translateY(0)}
  </style>
</head>
<body>

<div id="header">
  <a href="/courses">
    <div class="header-left" style="gap:6px">
      <span style="font-size:22px;color:#64748b">‹</span>
      <span style="font-size:14px;font-weight:600;color:#1a2332">Lessons</span>
    </div>
    <div style="font-size:13px;color:#64748b;font-weight:500">Lesson <%= lesson.id %> of 5</div>
    <div style="display:flex;align-items:center;gap:4px">
      <span style="font-size:13px;font-weight:700;color:#F9A61B">+<%= lesson.xp %> XP</span>
    </div>
  </a>
</div>

<div class="lesson-progress-top"><div class="lesson-progress-fill" id="lessonFill"></div></div>

<div class="lesson-video">
  <iframe src="https://www.youtube.com/embed/<%= lesson.videoId %>?rel=0&modestbranding=1" frameborder="0" allowfullscreen loading="lazy"></iframe>
</div>

<div class="lesson-content">
  <div class="xp-badge">⭐ +<%= lesson.xp %> XP · 🪙 +<%= lesson.coins %> Coins</div>
  <h1><%= lesson.title %></h1>
  <p><%= lesson.description %></p>
</div>

<div class="key-fact">
  💡 <strong>Quick Fact:</strong> <% if(lesson.id===1){ %>Money has existed for over 3,000 years — ancient civilizations used shells, beads, and metals as currency!<% } else if(lesson.id===2){ %>People who automate their savings are 3x more likely to reach their financial goals.<% } else if(lesson.id===3){ %>The average American spends $1,500 per year on impulse purchases they later regret.<% } else if(lesson.id===4){ %>Diversified portfolios have historically recovered from every major market crash in history.<% } else { %>Someone who invests $1,000 at age 15 could have over $88,000 by age 65 (at 8% annual return)!<% } %>
</div>

<button class="complete-btn" id="completeBtn" onclick="completeLessonFlow(<%= lesson.id %>, <%= lesson.xp %>, <%= lesson.coins %>)">
  ✅ Complete Lesson &amp; Take Quiz
</button>

<% if(lesson.upNextId) { %>
<div class="up-next-section">
  <h2>Up Next</h2>
  <div class="up-next-card">
    <span>📖 <%= lesson.upNext %></span>
    <span style="color:#2AA46A;font-weight:600">›</span>
  </div>
</div>
<% } else { %>
<div class="up-next-section">
  <h2>🏆 Final Lesson!</h2>
  <div class="up-next-card">
    <span>Complete this to become a certified money master!</span>
    <span>🎓</span>
  </div>
</div>
<% } %>

<div class="xp-flyout" id="xpFlyout">⭐ +<%= lesson.xp %> XP earned!</div>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
<script>
// Animate lesson progress bar as user reads
let fillPct = 0;
const fill = document.getElementById('lessonFill');
setTimeout(() => { fill.style.width = '40%'; }, 500);
setTimeout(() => { fill.style.width = '75%'; }, 3000);

// Check if already completed
const completed = JSON.parse(localStorage.getItem('li_completed_lessons') || '[]');
const lessonId = <%= lesson.id %>;
if (completed.includes(lessonId)) {
  const btn = document.getElementById('completeBtn');
  btn.textContent = '🔄 Revisit Quiz';
  btn.style.background = 'linear-gradient(135deg,#2A3140,#1a2332)';
}

function completeLessonFlow(id, xp, coins) {
  document.getElementById('lessonFill').style.width = '100%';
  
  // Mark as complete in localStorage
  const completed = JSON.parse(localStorage.getItem('li_completed_lessons') || '[]');
  if (!completed.includes(id)) {
    completed.push(id);
    localStorage.setItem('li_completed_lessons', JSON.stringify(completed));
    
    // Award XP & coins
    const prevXP = parseInt(localStorage.getItem('li_xp') || '0');
    const prevCoins = parseInt(localStorage.getItem('li_coins') || '800');
    const prevLevel = Math.floor(prevXP / 200);
    const newXP = prevXP + xp;
    const newLevel = Math.floor(newXP / 200);
    localStorage.setItem('li_xp', newXP);
    localStorage.setItem('li_level', newLevel);
    localStorage.setItem('li_coins', prevCoins + coins);
    localStorage.setItem('li_lessons_completed', completed.length);
    
    // First lesson achievement
    if (completed.length === 1) localStorage.setItem('li_ach_first_lesson', '1');
    
    // Show XP flyout
    const flyout = document.getElementById('xpFlyout');
    flyout.classList.add('show');
    setTimeout(() => flyout.classList.remove('show'), 2800);
    
    // Confetti on level up
    if (newLevel > prevLevel && typeof confetti !== 'undefined') {
      confetti({particleCount:100,spread:80,origin:{y:0.6},colors:['#2AA46A','#F9A61B','#34d399','#fff']});
    }
  }
  
  // Navigate to quiz after brief delay
  setTimeout(() => { window.location.href = '/quiz?lesson=' + id; }, 800);
}
</script>
</body>
</html>
