<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Family Dashboard — LittleInvestors</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" type="image/x-icon" href="/img/penny_logo.png">
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script src="/js/pendo-init.js"></script>
  <style>
    .parent-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      padding: 0 20px;
      margin-bottom: 16px;
    }
    .chore-chip {
      background: #fff;
      border: 1.5px solid #e2e8f0;
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 600;
      color: var(--dark);
      cursor: pointer;
      text-align: left;
      transition: var(--tr);
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
    }
    .chore-chip:hover {
      border-color: var(--green);
      background: var(--light);
      transform: translateY(-1px);
    }
    .chore-chip.active {
      border-color: var(--green);
      background: var(--light);
      box-shadow: 0 0 0 2px rgba(42, 164, 106, 0.15);
    }
    .portfolio-pie {
      display: flex;
      align-items: center;
      gap: 20px;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: var(--r);
      padding: 16px;
      margin: 0 20px 16px;
    }
    .pie-chart {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background: conic-gradient(var(--green) 0% 40%, var(--gold) 40% 70%, var(--navy) 70% 100%);
      flex-shrink: 0;
    }
    .pie-legend {
      flex: 1;
      font-size: 12px;
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 4px;
      font-weight: 500;
      color: var(--dark);
    }
    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }
  .pin-dot{width:16px;height:16px;border-radius:50%;border:2px solid rgba(255,255,255,.3);background:transparent;transition:all .15s ease}
  .pin-dot.filled{background:#2AA46A;border-color:#2AA46A;box-shadow:0 0 10px rgba(42,164,106,.6);transform:scale(1.1)}
  .pin-dot.error{background:#EF4444;border-color:#EF4444;box-shadow:0 0 10px rgba(239,68,68,.5)}
  .keypad-btn{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:50%;width:72px;height:72px;color:#fff;font-size:22px;font-weight:600;cursor:pointer;transition:all .15s ease;display:flex;align-items:center;justify-content:center;font-family:'Inter',sans-serif;-webkit-tap-highlight-color:transparent;user-select:none}
  .keypad-btn:hover{background:rgba(255,255,255,.15)}
  .keypad-btn:active{transform:scale(.92);background:rgba(42,164,106,.35)}
  @keyframes pinShake{0%,100%{transform:translateX(0)}15%{transform:translateX(-10px)}30%{transform:translateX(10px)}45%{transform:translateX(-7px)}60%{transform:translateX(7px)}75%{transform:translateX(-4px)}90%{transform:translateX(4px)}}
  .pin-shake{animation:pinShake .5s cubic-bezier(.36,.07,.19,.97) both}
  </style>
</head>
<body>

<!-- Parent Passcode Overlay -->
<div id="passcodeOverlay" style="position:fixed;inset:0;background:rgba(10, 15, 30, 0.75);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:all 0.4s ease;">
  <div style="text-align:center;max-width:300px;width:100%;padding:0 32px">
    <div style="font-size:52px;margin-bottom:20px;transition:all .3s" id="lockEmoji">🔒</div>
    <h2 style="color:#fff;font-size:24px;font-weight:800;margin-bottom:8px;letter-spacing:-.5px">Parent Mode</h2>
    <p style="color:rgba(255,255,255,.5);font-size:14px;margin-bottom:40px;line-height:1.6" id="pinStatusMsg">Enter your 4-digit PIN to<br>access the Family Dashboard</p>
    <div style="display:flex;gap:20px;justify-content:center;margin-bottom:48px" id="pinDotsRow">
      <div class="pin-dot" id="dot0"></div>
      <div class="pin-dot" id="dot1"></div>
      <div class="pin-dot" id="dot2"></div>
      <div class="pin-dot" id="dot3"></div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,72px);gap:14px;justify-content:center">
      <button class="keypad-btn" onclick="pinPress('1')">1</button>
      <button class="keypad-btn" onclick="pinPress('2')">2</button>
      <button class="keypad-btn" onclick="pinPress('3')">3</button>
      <button class="keypad-btn" onclick="pinPress('4')">4</button>
      <button class="keypad-btn" onclick="pinPress('5')">5</button>
      <button class="keypad-btn" onclick="pinPress('6')">6</button>
      <button class="keypad-btn" onclick="pinPress('7')">7</button>
      <button class="keypad-btn" onclick="pinPress('8')">8</button>
      <button class="keypad-btn" onclick="pinPress('9')">9</button>
      <button class="keypad-btn" onclick="pinClear()" style="font-size:13px;font-weight:700;letter-spacing:.5px">CLR</button>
      <button class="keypad-btn" onclick="pinPress('0')">0</button>
      <button class="keypad-btn" onclick="pinDelete()" style="font-size:22px">⌫</button>
    </div>
    <p style="color:rgba(255,255,255,.22);font-size:12px;margin-top:32px">First time? Default PIN is <strong style="color:rgba(255,255,255,.4)">0000</strong></p>
    <a href="/home" style="display:inline-block;margin-top:14px;color:rgba(255,255,255,.3);font-size:13px;font-weight:500;text-decoration:none">← Back to App</a>
  </div>
</div>

<!-- Change PIN Modal -->
<div id="changePinModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:10000;align-items:flex-end;justify-content:center">
  <div style="background:#fff;border-radius:24px 24px 0 0;padding:28px 24px;width:100%;max-width:430px">
    <div style="font-size:18px;font-weight:800;color:#1a2332;margin-bottom:6px">🔑 Change Parent PIN</div>
    <div style="font-size:13px;color:#64748b;margin-bottom:20px">Enter a new 4-digit PIN for Parent Mode</div>
    <input type="tel" id="newPinInput" placeholder="• • • •" maxlength="4" inputmode="numeric" pattern="[0-9]*" style="width:100%;padding:14px;border-radius:12px;border:1.5px solid #e2e8f0;font-size:28px;letter-spacing:14px;text-align:center;margin-bottom:16px;font-weight:800;font-family:'Inter',sans-serif" oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,4)">
    <button onclick="saveNewPin()" style="width:100%;padding:14px;background:linear-gradient(135deg,#2AA46A,#1b7a4e);color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif">Save New PIN 🔐</button>
    <button onclick="document.getElementById('changePinModal').style.display='none'" style="width:100%;padding:12px;background:#f8fafc;color:#64748b;border:none;border-radius:12px;font-size:14px;font-weight:600;cursor:pointer;margin-top:8px;font-family:'Inter',sans-serif">Cancel</button>
  </div>
</div>

<div class="parent-header">
  <a href="/home" style="color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;display:inline-flex;align-items:center;gap:6px;margin-bottom:12px;font-weight:600">‹ Back to App</a>
  <div style="display:flex;justify-content:space-between;align-items:center;width:100%">
    <div>
      <div class="parent-badge">👨‍👩‍👧 Family Dashboard</div>
      <h1 style="color:#fff;font-size:22px;font-weight:800;letter-spacing:-0.5px">Parent Control Center</h1>
    </div>
    <button onclick="showChangePinModal()" style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);color:#fff;padding:8px 16px;border-radius:20px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s" onmouseover="this.style.background='rgba(255,255,255,.25)'" onmouseout="this.style.background='rgba(255,255,255,.15)'">🔑 PIN</button>
  </div>
</div>

<div class="parent-grid">
  <div class="stat-card" style="margin:0">
    <h3>Child's Balance</h3>
    <div class="stat-val" id="parentBalance">🪙 800</div>
    <div class="stat-sub" style="color:var(--green)">available pocket coins</div>
  </div>
  <div class="stat-card" style="margin:0">
    <h3>Streak</h3>
    <div class="stat-val" id="parentStreak">🔥 30</div>
    <div class="stat-sub" style="color:var(--gold)">days active learning</div>
  </div>
  <div class="stat-card" style="margin:0">
    <h3>XP Points</h3>
    <div class="stat-val" id="parentXP">100</div>
    <div class="stat-sub" style="color:var(--green)">total rewards earned</div>
  </div>
  <div class="stat-card" style="margin:0">
    <h3>Validator Level</h3>
    <div class="stat-val" id="parentLevel">0</div>
    <div class="stat-sub" style="color:var(--navy)">learning tier</div>
  </div>
</div>

<!-- Child's Active Savings Goal -->
<div class="stat-card" id="parentGoalCard" style="display:none">
  <h3>Child's Active Goal</h3>
  <div style="display:flex;justify-content:between;align-items:center;margin-top:6px;margin-bottom:8px">
    <span style="font-size:15px;font-weight:700;color:var(--dark)" id="goalName">New Bike</span>
    <span style="font-size:14px;font-weight:700;color:var(--gold)" id="goalPct">40% complete</span>
  </div>
  <div class="progress-bar"><div class="progress" id="goalProgress" style="width:40%"></div></div>
  <div style="font-size:12px;color:var(--gray);margin-top:6px;display:flex;justify-content:space-between">
    <span id="goalSaved">Saved: 🪙 320</span>
    <span id="goalTarget">Goal Target: 🪙 800</span>
  </div>
</div>

<!-- Portfolio breakdown -->
<div style="padding:0 20px 8px 20px"><div style="font-size:13px;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:0.5px">💼 Token Allocation</div></div>
<div class="portfolio-pie">
  <div class="pie-chart" id="pieChart"></div>
  <div class="pie-legend" id="pieLegend">
    <div class="legend-item"><span class="legend-dot" style="background:var(--green)"></span> Cash Coins: <span id="cashPct" style="font-weight:700">100%</span></div>
    <div class="legend-item"><span class="legend-dot" style="background:var(--gold)"></span> Tokens: <span id="stocksPct" style="font-weight:700">0%</span></div>
  </div>
</div>

<!-- Web3 Vault Panel -->
<div class="send-money-card" style="background: linear-gradient(135deg, #0f172a, #1e293b); color: #fff; border: none; margin-top: 12px;">
  <h3 style="color:#fff; margin-bottom: 8px;">🔐 Soroban Smart Vault</h3>
  <p style="color: rgba(255,255,255,0.6); font-size: 13px; line-height: 1.4; margin-bottom: 16px;">
    Connect your Freighter wallet to deploy and control your child's on-chain Soroban allowance vault contract.
  </p>
  
  <!-- Wallet state control -->
  <div id="walletSection" style="display: flex; flex-direction: column; gap: 10px;">
    <button id="connectWalletBtn" onclick="handleWalletConnect()" class="send-btn-big" style="background: #2AA46A; color:#fff; border:none; border-radius:12px; cursor:pointer;">
      🔌 Connect Freighter Wallet
    </button>
    <button id="createLocalParentBtn" onclick="handleCreateLocalParent()" class="send-btn-big" style="background: #38bdf8; color:#0f172a; border:none; border-radius:12px; cursor:pointer; font-weight:700;">
      🔑 Generate Local Parent Account (No Extension)
    </button>
    
    <div id="walletDetails" style="display: none; background: rgba(255,255,255,0.06); padding: 12px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); font-size:13px;">
      <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
        <span style="color:rgba(255,255,255,0.5)">Address:</span>
        <span id="walletAddressDisplay" style="font-family:monospace; font-weight:700; color:#2AA46A;">GA...</span>
      </div>
      <div style="display:flex; justify-content:space-between; margin-bottom:12px;">
        <span style="color:rgba(255,255,255,0.5)">Testnet Balance:</span>
        <span id="walletBalanceDisplay" style="font-weight:700; color:#ffd700;">0.00 XLM</span>
      </div>
      <div style="display:flex; gap: 8px;">
        <button onclick="handleFaucetClaim()" class="wallet-action-btn" style="flex:1; background:rgba(255,255,255,0.1); color:#fff; padding:6px; font-size:11px; border-radius:6px; border:1px solid rgba(255,255,255,0.15); cursor:pointer;">
          🪙 Get Testnet XLM
        </button>
        <button onclick="handleWalletDisconnect()" class="wallet-action-btn" style="flex:1; background:rgba(239,68,68,0.2); color:#ef4444; padding:6px; font-size:11px; border-radius:6px; border:1px solid rgba(239,68,68,0.3); cursor:pointer;">
          Disconnect
        </button>
      </div>
    </div>
  </div>

  <!-- Contract deployment / control -->
  <div id="vaultControlSection" style="display: none; margin-top: 16px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; flex-direction:column; gap:12px;">
    
    <!-- Child account generation -->
    <div id="childAccountDetails" style="background: rgba(255,255,255,0.04); padding: 12px; border-radius: 10px; font-size:12px;">
      <div style="font-weight:700; margin-bottom: 6px; color:#38bdf8;">👦 Child Profile Account</div>
      <div id="noChildAccount" style="display:flex; justify-content:space-between; align-items:center;">
        <span style="color:rgba(255,255,255,0.5)">No on-chain child account yet.</span>
        <button onclick="handleCreateChild()" style="background:#38bdf8; border:none; padding:6px 12px; font-size:11px; font-weight:700; border-radius:6px; color:#0f172a; cursor:pointer;">Generate Account</button>
      </div>
      <div id="childAccountDisplay" style="display:none; flex-direction:column; gap:4px;">
        <div style="display:flex; justify-content:space-between;">
          <span style="color:rgba(255,255,255,0.5)">Public Address:</span>
          <span id="childPubkeyDisplay" style="font-family:monospace; color:#38bdf8;">GD...</span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span style="color:rgba(255,255,255,0.5)">Testnet Balance:</span>
          <span id="childBalanceDisplay" style="color:#ffd700; font-weight:700;">0.00 XLM</span>
        </div>
      </div>
    </div>

    <!-- Contract deployment -->
    <div id="deployVaultContainer">
      <button id="deployVaultBtn" onclick="handleDeployVault()" class="send-btn-big" style="background: #e2e8f0; color:#0f172a; border:none; border-radius:12px; cursor:pointer; width:100%;">
        🚀 Deploy Allowance Vault Contract
      </button>
    </div>

    <!-- Contract initialized display -->
    <div id="contractDisplay" style="display:none; background: rgba(255,255,255,0.06); padding: 12px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); font-size:12px; flex-direction:column; gap:6px;">
      <div style="display:flex; justify-content:space-between;">
        <span style="color:rgba(255,255,255,0.5)">Vault Contract ID:</span>
        <a id="contractLink" href="#" target="_blank" style="font-family:monospace; color:#2aa46a; font-weight:700; text-decoration:underline;">C...</a>
      </div>
      <div id="vaultStatsDisplay" style="display:flex; flex-direction:column; gap:4px; border-top: 1px solid rgba(255,255,255,0.1); margin-top:6px; padding-top:6px;">
        <div style="display:flex; justify-content:space-between;">
          <span style="color:rgba(255,255,255,0.5)">Daily Spend Limit:</span>
          <span id="vaultDailyLimitDisplay" style="font-weight:700; color:#fff;">0 XLM</span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span style="color:rgba(255,255,255,0.5)">Spent Today:</span>
          <span id="vaultSpentDisplay" style="font-weight:700; color:#ef4444;">0 XLM</span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span style="color:rgba(255,255,255,0.5)">Saved Vault Pool:</span>
          <span id="vaultSavedDisplay" style="font-weight:700; color:#2aa46a;">0 XLM</span>
        </div>
      </div>
    </div>

    <!-- Contract limit controls -->
    <div id="vaultSettingsContainer" style="display:none; flex-direction:column; gap:8px;">
      <div style="font-weight:700; font-size:13px; color:rgba(255,255,255,0.8)">Modify Spending Limit:</div>
      <div style="display:flex; gap:6px;">
        <input type="number" id="newSpendLimitInput" placeholder="Limit in XLM (e.g. 10)" style="flex:1; padding:10px; border-radius:8px; border:1px solid rgba(255,255,255,0.2); background:rgba(0,0,0,0.2); color:#fff; font-size:13px;">
        <button onclick="handleUpdateLimit()" style="background:#2AA46A; color:#fff; border:none; padding:8px 12px; font-size:12px; font-weight:700; border-radius:8px; cursor:pointer;">Update</button>
      </div>
    </div>

  </div>
</div>

<div class="send-money-card">
  <h3>💸 Fast Allowance Transfer</h3>
  <div class="amount-btns" id="amountBtns">
    <button class="amount-btn" onclick="selectAmount(5,this)">🪙 5</button>
    <button class="amount-btn" onclick="selectAmount(10,this)">🪙 10</button>
    <button class="amount-btn" onclick="selectAmount(25,this)">🪙 25</button>
    <button class="amount-btn" onclick="selectAmount(50,this)">🪙 50</button>
  </div>
  <button class="send-btn-big" onclick="sendMoney()">Send Selected Allowance 📤</button>
</div>

<div class="send-money-card" style="margin-top:12px">
  <h3>🧹 Reward Chores & Learning Tasks</h3>
  <div style="display:flex;flex-direction:column;gap:8px;margin-top:12px">
    <button class="chore-chip" onclick="selectChore('Reading a book 📚', 5, this)">
      <span>📚</span><span>Reading a book for 30m</span><span style="margin-left:auto;color:var(--green)">+🪙 5</span>
    </button>
    <button class="chore-chip" onclick="selectChore('Math Homework ✏️', 10, this)">
      <span>✏️</span><span>Completing Math homework</span><span style="margin-left:auto;color:var(--green)">+🪙 10</span>
    </button>
    <button class="chore-chip" onclick="selectChore('Clean Room 🧹', 15, this)">
      <span>🧹</span><span>Cleaning bedroom & bed</span><span style="margin-left:auto;color:var(--green)">+🪙 15</span>
    </button>
    <button class="chore-chip" onclick="selectChore('Write Smart Contract 💻', 20, this)">
      <span>💻</span><span>Helping write a smart contract</span><span style="margin-left:auto;color:var(--green)">+🪙 20</span>
    </button>
  </div>
  
  <div style="display:flex;flex-direction:column;gap:10px;margin-top:16px;border-top:1px solid #e2e8f0;padding-top:14px">
    <div style="font-size:13px;font-weight:700;color:var(--dark)">Or create a custom reward note:</div>
    <input type="number" id="customAmount" placeholder="Reward amount (coins)" style="width:100%;padding:12px;border-radius:12px;border:1px solid #e2e8f0;font-size:14px;font-weight:600">
    <input type="text" id="customNote" placeholder="Personal note (e.g. Great job writing that block! 💻)" style="width:100%;padding:12px;border-radius:12px;border:1px solid #e2e8f0;font-size:14px">
    <button class="send-btn-big" onclick="sendCustomReward()" style="background:var(--navy)">Send Custom Reward 🚀</button>
  </div>
</div>

<div style="padding:16px 20px 8px 20px"><div style="font-size:13px;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:0.5px">📋 Family Activity History</div></div>
<div class="activity-list" id="activityList">
  <!-- dynamically loaded from localStorage below -->
</div>

<div style="padding:20px">
  <div style="background:#fef9ee;border:1px solid #fde68a;border-radius:16px;padding:18px;text-align:center">
    <div style="font-size:24px;margin-bottom:8px">💡</div>
    <div style="font-size:14px;font-weight:700;color:#92400e;margin-bottom:4px">Tip for Parents</div>
    <div style="font-size:13px;color:#78350f;line-height:1.5">Web3 is built on cryptography and peer-to-peer networks. Ask your child what a private key does today!</div>
  </div>
</div>

<nav class="menu">
  <a href="/home"><img src="/img/menu (3).png" alt="home"><span class="menu-label">Home</span></a>
  <a href="/courses"><img src="/img/menu (4).png" alt="courses"><span class="menu-label">Learn</span></a>
  <a href="/chatbot"><img src="/img/menu (2).png" alt="chat"><span class="menu-label">Chat</span></a>
  <a href="/parent" class="active"><img src="/img/menu (1).png" alt="parent"><span class="menu-label">Parent</span></a>
</nav>

<div class="toast" id="toast"></div>
<script src="/js/script.js"></script>
<script src="/js/stellar-helper.js"></script>
<script>
// ===== PARENT PIN SYSTEM (VERIFIED) =====

let selectedAmount = 0;
let choreAmount = 0;
let choreNote = "";

function selectAmount(amt, el) {
  selectedAmount = amt;
  document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function selectChore(note, amt, el) {
  choreAmount = amt;
  choreNote = note;
  document.querySelectorAll('.chore-chip').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  
  // Auto populate custom input to give visibility
  document.getElementById('customAmount').value = amt;
  document.getElementById('customNote').value = "Reward for: " + note;
}

function sendMoney() {
  if (!selectedAmount) { showToast('Please select an allowance amount! 💸'); return; }
  
  if (typeof pendo !== 'undefined') {
    pendo.track('allowance_sent', { amount: selectedAmount });
  }

  transferCash(selectedAmount, "Pocket allowance sent! 💰");
  selectedAmount = 0;
  document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('active'));
}

function sendCustomReward() {
  const amtInput = document.getElementById('customAmount');
  const noteInput = document.getElementById('customNote');
  const amt = parseInt(amtInput.value);
  const note = noteInput.value.trim() || "Allowance payout! 💸";
  
  if (isNaN(amt) || amt <= 0) { showToast('Please enter a valid amount! 💰'); return; }
  
  if (typeof pendo !== 'undefined') {
    pendo.track('custom_reward_sent', { amount: amt, note: note });
  }

  transferCash(amt, note);
  
  amtInput.value = '';
  noteInput.value = '';
  document.querySelectorAll('.chore-chip').forEach(b => b.classList.remove('active'));
}

async function transferCash(amt, note) {
  const parentAddress = StellarHelper.getSavedAddress();
  const childAddress = localStorage.getItem('li_child_stellar_address');
  const contractId = localStorage.getItem('li_contract_id');
  const parentSecret = localStorage.getItem('li_parent_stellar_secret') || '';
  
  if (parentAddress && childAddress) {
    showToast('Initiating real on-chain allowance payment... ⏳');
    try {
      // 1. Perform XLM transfer from parent to child on Stellar testnet
      const paymentRes = await StellarHelper.sendPayment(parentAddress, childAddress, amt, parentSecret);
      if (!paymentRes.success) {
        showToast('❌ On-Chain Payment Error: ' + (paymentRes.error || 'Failed to send payment.'));
        return;
      }
      
      // 2. If a contract is deployed, update the saved pool on-chain
      if (contractId) {
        showToast('Depositing coins into Smart Vault... ⚙️');
        const saveRes = await StellarHelper.vaultSave(contractId, amt);
        if (!saveRes.success) {
          showToast('⚠️ Note: On-chain payment succeeded, but vault contract state update failed.');
        } else {
          showToast('✅ Allowance deposited into Smart Vault on-chain!');
        }
      } else {
        showToast('✅ Allowance sent successfully on-chain!');
      }
      
      // Update child's balance in parent view
      const childData = await StellarHelper.getParentBalance(childAddress);
      if (childData.success) {
        document.getElementById('childBalanceDisplay').textContent = parseFloat(childData.balance).toFixed(2) + ' XLM';
      }
    } catch (e) {
      showToast('❌ On-Chain Error: ' + e.message);
      return;
    }
  }

  const bal = parseFloat(localStorage.getItem('li_coins') || '800');
  const newBal = Math.round((bal + amt) * 100) / 100;
  localStorage.setItem('li_coins', newBal);
  
  // Update header and displays
  document.getElementById('parentBalance').textContent = '🪙 ' + newBal;
  const coinAmt = document.getElementById('coinAmount');
  if (coinAmt) coinAmt.textContent = newBal;

  // Add notification to localStorage
  const notifs = JSON.parse(localStorage.getItem('li_notifications') || '[]');
  notifs.push({
    id: 'notif_' + Date.now(),
    icon: '💸',
    title: `Parent sent you ${amt} coins!`,
    sub: note,
    time: 'Just now'
  });
  localStorage.setItem('li_notifications', JSON.stringify(notifs));

  // Add activity log
  const list = document.getElementById('activityList');
  const item = document.createElement('div');
  item.className = 'activity-item';
  item.style.animation = 'slideIn .3s ease';
  item.innerHTML = `<div class="activity-dot green">💸</div><div class="activity-info"><div class="activity-title">${note}</div><div class="activity-time">Just now</div></div><div class="activity-val" style="color:var(--green)">+🪙 ${amt}</div>`;
  if (list) {
    if (list.querySelector('.activity-item') || list.innerHTML.includes('No activity')) {
      if (list.innerHTML.includes('No activity')) list.innerHTML = '';
      list.prepend(item);
    } else {
      list.appendChild(item);
    }
  }
  
  if (typeof confetti !== 'undefined') {
    confetti({particleCount: 50, spread: 60, origin: {y: 0.6}});
  }
  
  showToast(`✅ ${amt} coins transfer successful!`);
  
  // Recalculate portfolio allocation pie
  loadPortfolioStats();
  refreshWalletState();
}

function loadPortfolioStats() {
  const coins = parseFloat(localStorage.getItem('li_coins') || '800');
  const prices = { sol: 145.00, eth: 320.00, btc: 650.00, dot: 30.00, ada: 40.00, doge: 12.00 };
  let stocksVal = 0;
  
  Object.keys(prices).forEach(ticker => {
    const shares = parseFloat(localStorage.getItem('li_shares_' + ticker) || '0');
    stocksVal += shares * prices[ticker];
  });
  
  const total = coins + stocksVal;
  const cashPct = total > 0 ? Math.round((coins / total) * 100) : 100;
  const stocksPct = 100 - cashPct;
  
  const cashPctEl = document.getElementById('cashPct');
  const stocksPctEl = document.getElementById('stocksPct');
  if (cashPctEl) cashPctEl.textContent = cashPct + '%';
  if (stocksPctEl) stocksPctEl.textContent = stocksPct + '%';
  
  const pie = document.getElementById('pieChart');
  if (pie) {
    pie.style.background = `conic-gradient(var(--green) 0% ${cashPct}%, var(--gold) ${cashPct}% 100%)`;
  }
}

window.addEventListener('DOMContentLoaded', () => {
  // Skip PIN if already authenticated this browser session
  if (sessionStorage.getItem('li_parent_session') === '1') {
    const ov = document.getElementById('passcodeOverlay');
    if (ov) ov.style.display = 'none';
  }

  const xp = localStorage.getItem('li_xp') || '0';
  const level = localStorage.getItem('li_level') || '0';
  const coins = localStorage.getItem('li_coins') || '800';
  const streak = localStorage.getItem('li_streak') || '30';
  
  document.getElementById('parentXP').textContent = xp;
  document.getElementById('parentLevel').textContent = level;
  document.getElementById('parentBalance').textContent = '🪙 ' + parseFloat(coins).toFixed(0);
  document.getElementById('parentStreak').textContent = '🔥 ' + streak;
  
  // Load goal progress
  const goal = JSON.parse(localStorage.getItem('li_savings_goal') || 'null');
  if (goal) {
    const goalCard = document.getElementById('parentGoalCard');
    if (goalCard) {
      goalCard.style.display = 'block';
      document.getElementById('goalName').textContent = goal.name;
      document.getElementById('goalTarget').textContent = 'Goal Target: 🪙 ' + goal.amount;
      document.getElementById('goalSaved').textContent = 'Saved: 🪙 ' + parseFloat(coins).toFixed(0);
      
      const pct = Math.min(100, Math.round((parseFloat(coins) / goal.amount) * 100));
      document.getElementById('goalPct').textContent = pct + '% complete';
      document.getElementById('goalProgress').style.width = pct + '%';
    }
  }
  
  loadPortfolioStats();

  // ── Dynamic Activity History ──
  const list = document.getElementById('activityList');
  if (list) {
    const lessonTitles = {
      1: 'What is a Blockchain?',
      2: 'Cryptography & Blocks',
      3: 'Coins & Wallets',
      4: 'How Consensus Works',
      5: 'Smart Contracts & Web3'
    };
    const lessonXP = {1:100,2:120,3:140,4:160,5:200};
    const activities = [];

    // Lesson completions
    const completedLessons = JSON.parse(localStorage.getItem('li_completed_lessons') || '[]');
    completedLessons.forEach(id => {
      activities.push({ dot: '✅', dotClass: 'green', title: 'Completed: ' + (lessonTitles[id] || 'Lesson ' + id), time: 'Lesson · +' + (lessonXP[id] || 100) + ' XP', val: '+' + (lessonXP[id] || 100) + ' XP', valColor: 'var(--green)' });
      activities.push({ dot: '🎯', dotClass: 'gold', title: 'Quiz: ' + (lessonTitles[id] || 'Lesson ' + id), time: 'Quiz completed', val: '+XP', valColor: 'var(--gold)' });
    });

    // Allowance transfers from notifications
    const notifs = JSON.parse(localStorage.getItem('li_notifications') || '[]');
    notifs.filter(n => n.icon === '💸').forEach(n => {
      activities.push({ dot: '💸', dotClass: 'green', title: n.title, time: n.time || 'Recently', val: '', valColor: 'var(--green)' });
    });

    // Stock/token purchases
    const totalShares = parseInt(localStorage.getItem('li_total_shares') || '0');
    if (totalShares > 0) {
      activities.push({ dot: '📈', dotClass: 'green', title: 'Bought tokens in simulator', time: totalShares + ' token' + (totalShares !== 1 ? 's' : '') + ' owned', val: totalShares + ' tokens', valColor: 'var(--navy)' });
    }

    if (activities.length === 0) {
      list.innerHTML = '<div style="padding:16px 20px;text-align:center;color:var(--gray);font-size:14px">No activity yet — your child hasn\'t started learning! 📚</div>';
    } else {
      list.innerHTML = '';
      activities.slice(-6).reverse().forEach(a => {
        const item = document.createElement('div');
        item.className = 'activity-item';
        item.innerHTML = `<div class="activity-dot ${a.dotClass}">${a.dot}</div><div class="activity-info"><div class="activity-title">${a.title}</div><div class="activity-time">${a.time}</div></div><div class="activity-val" style="color:${a.valColor}">${a.val}</div>`;
        list.appendChild(item);
      });
    }
    // Load wallet state
    refreshWalletState();
  }
});

// ===== WALLET AND VAULT LOGIC =====
async function refreshWalletState() {
  const address = StellarHelper.getSavedAddress();
  if (address) {
    document.getElementById('connectWalletBtn').style.display = 'none';
    if (document.getElementById('createLocalParentBtn')) {
      document.getElementById('createLocalParentBtn').style.display = 'none';
    }
    document.getElementById('walletDetails').style.display = 'block';
    document.getElementById('walletAddressDisplay').textContent = address.slice(0,6) + '...' + address.slice(-4);
    
    // Show vault control section
    document.getElementById('vaultControlSection').style.display = 'flex';

    // Fetch balance
    const parentData = await StellarHelper.getParentBalance(address);
    if (parentData.success) {
      document.getElementById('walletBalanceDisplay').textContent = parseFloat(parentData.balance).toFixed(2) + ' XLM';
    }

    // Refresh child details if exist
    const childAddress = localStorage.getItem('li_child_stellar_address');
    if (childAddress) {
      document.getElementById('noChildAccount').style.display = 'none';
      document.getElementById('childAccountDisplay').style.display = 'flex';
      document.getElementById('childPubkeyDisplay').textContent = childAddress.slice(0,6) + '...' + childAddress.slice(-4);
      
      const childData = await StellarHelper.getParentBalance(childAddress);
      if (childData.success) {
        document.getElementById('childBalanceDisplay').textContent = parseFloat(childData.balance).toFixed(2) + ' XLM';
        // Sync local storage display
        const localCoins = localStorage.getItem('li_coins') || '800';
        document.getElementById('parentBalance').textContent = '🪙 ' + parseFloat(localCoins).toFixed(0);
      }
    } else {
      document.getElementById('noChildAccount').style.display = 'flex';
      document.getElementById('childAccountDisplay').style.display = 'none';
    }

    // Refresh contract details if exist
    const contractId = localStorage.getItem('li_contract_id');
    if (contractId) {
      document.getElementById('deployVaultContainer').style.display = 'none';
      document.getElementById('contractDisplay').style.display = 'flex';
      document.getElementById('vaultSettingsContainer').style.display = 'flex';
      
      const link = document.getElementById('contractLink');
      link.textContent = contractId.slice(0,6) + '...' + contractId.slice(-4);
      link.href = `https://stellar.expert/explorer/testnet/contract/${contractId}`;
      
      // Load details from the contract
      const details = await StellarHelper.getVaultDetails(contractId);
      if (details.success && details.details) {
        try {
          const parts = details.details.replace(/[()\[\]"]/g, '').split(',');
          if (parts.length >= 5) {
            const savedPoolVal = parts[4].trim();
            document.getElementById('vaultDailyLimitDisplay').textContent = parts[2].trim() + ' XLM';
            document.getElementById('vaultSpentDisplay').textContent = parts[3].trim() + ' XLM';
            document.getElementById('vaultSavedDisplay').textContent = savedPoolVal + ' XLM';
            
            // Sync top header child balance display to the vault's saved_pool
            document.getElementById('parentBalance').textContent = '🪙 ' + parseFloat(savedPoolVal).toFixed(0);
            localStorage.setItem('li_coins', parseFloat(savedPoolVal).toFixed(0));
          }
        } catch(e) {
          console.error("Failed to parse vault details:", e);
        }
      }
    } else {
      document.getElementById('deployVaultContainer').style.display = 'block';
      document.getElementById('contractDisplay').style.display = 'none';
      document.getElementById('vaultSettingsContainer').style.display = 'none';
    }

  } else {
    document.getElementById('connectWalletBtn').style.display = 'block';
    if (document.getElementById('createLocalParentBtn')) {
      document.getElementById('createLocalParentBtn').style.display = 'block';
    }
    document.getElementById('walletDetails').style.display = 'none';
    document.getElementById('vaultControlSection').style.display = 'none';
  }
}

async function handleWalletConnect() {
  try {
    const key = await StellarHelper.connectWallet();
    showToast('Freighter connected successfully! 🔌');
    refreshWalletState();
  } catch(e) {
    showToast(e.message);
  }
}

async function handleCreateLocalParent() {
  showToast('Generating local parent account... 🔑');
  try {
    const res = await fetch('/api/stellar/child/create', { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      localStorage.setItem('li_parent_stellar_address', data.publicKey);
      localStorage.setItem('li_parent_stellar_secret', data.secret);
      showToast('Local parent account created & funded! 🪙');
      refreshWalletState();
    } else {
      showToast('Failed to create parent account.');
    }
  } catch(e) {
    showToast('Error: ' + e.message);
  }
}

function handleWalletDisconnect() {
  StellarHelper.disconnectWallet();
  showToast('Wallet disconnected.');
  refreshWalletState();
}

async function handleFaucetClaim() {
  const address = StellarHelper.getSavedAddress();
  if (!address) return;
  showToast('Requesting faucet funds... 🪙');
  const res = await StellarHelper.fundAccount(address);
  if (res.success) {
    showToast(res.message);
    refreshWalletState();
  } else {
    showToast('Failed to claim testnet XLM.');
  }
}

async function handleCreateChild() {
  showToast('Creating child profile on-chain... 👦');
  const res = await StellarHelper.createChildProfile();
  if (res.success) {
    showToast('Child profile created and funded on Testnet! 🪙');
    refreshWalletState();
  } else {
    showToast('Failed to create child profile.');
  }
}

async function handleDeployVault() {
  showToast('Deploying Soroban vault wasm... 🚀');
  const res = await StellarHelper.deployVault();
  if (res.success) {
    showToast('Vault deployed! Initializing... ⚙️');
    const parent = StellarHelper.getSavedAddress();
    const child = localStorage.getItem('li_child_stellar_address');
    if (!child) {
      showToast('Please generate a child account first.');
      return;
    }
    const initRes = await StellarHelper.initializeVault(res.contractId, parent, child, 10);
    if (initRes.success) {
      showToast('Smart Vault successfully initialized on Testnet! 🎉');
      logOnchainActivity('Deployed & Initialized Vault', res.contractId);
    } else {
      showToast('Failed to initialize vault: ' + initRes.error);
    }
    refreshWalletState();
  } else {
    showToast('Failed to deploy vault WASM.');
  }
}

async function handleUpdateLimit() {
  const limitInput = document.getElementById('newSpendLimitInput');
  const limit = parseInt(limitInput.value);
  if (isNaN(limit) || limit <= 0) {
    showToast('Please enter a valid spending limit.');
    return;
  }
  const contractId = localStorage.getItem('li_contract_id');
  if (!contractId) return;
  showToast('Updating daily spend limit on-chain... ⚙️');
  const res = await StellarHelper.setSpendingLimit(contractId, limit);
  if (res.success) {
    showToast(`Daily limit updated to ${limit} XLM! ✅`);
    limitInput.value = '';
    logOnchainActivity('Updated daily limit to ' + limit + ' XLM', contractId);
    refreshWalletState();
  } else {
    showToast('Failed to update limit.');
  }
}

function logOnchainActivity(note, details) {
  const notifs = JSON.parse(localStorage.getItem('li_notifications') || '[]');
  notifs.push({
    id: 'notif_' + Date.now(),
    icon: '🔗',
    title: note,
    sub: 'Contract: ' + details.slice(0,8) + '...',
    time: 'Just now'
  });
  localStorage.setItem('li_notifications', JSON.stringify(notifs));
}

let enteredPin = '';

function pinPress(digit) {
  if (enteredPin.length >= 4) return;
  enteredPin += digit;
  updatePinDots();
  
  if (enteredPin.length === 4) {
    const correctPin = localStorage.getItem('li_parent_pin') || '0000';
    if (enteredPin === correctPin) {
      document.getElementById('lockEmoji').textContent = '🔓';
      document.getElementById('pinStatusMsg').innerHTML = '<span style="color:#2AA46A;font-weight:700">Access Granted!</span>';
      sessionStorage.setItem('li_parent_session', '1');
      setTimeout(() => {
        const ov = document.getElementById('passcodeOverlay');
        if (ov) {
          ov.style.transition = 'opacity 0.4s ease';
          ov.style.opacity = '0';
          setTimeout(() => ov.style.display = 'none', 400);
        }
      }, 500);
    } else {
      // Shake dots
      const dotsRow = document.getElementById('pinDotsRow');
      dotsRow.classList.add('pin-shake');
      document.querySelectorAll('.pin-dot').forEach(dot => dot.classList.add('error'));
      document.getElementById('pinStatusMsg').innerHTML = '<span style="color:#ef4444;font-weight:700">Incorrect PIN! Try again.</span>';
      
      setTimeout(() => {
        dotsRow.classList.remove('pin-shake');
        enteredPin = '';
        updatePinDots();
      }, 1000);
    }
  }
}

function pinClear() {
  enteredPin = '';
  updatePinDots();
}

function pinDelete() {
  if (enteredPin.length > 0) {
    enteredPin = enteredPin.slice(0, -1);
    updatePinDots();
  }
}

function updatePinDots() {
  const msg = document.getElementById('pinStatusMsg');
  if (enteredPin.length === 0 && (!msg.textContent || msg.textContent.includes('Incorrect'))) {
    msg.innerHTML = 'Enter your 4-digit PIN to<br>access the Family Dashboard';
  }
  
  for (let i = 0; i < 4; i++) {
    const dot = document.getElementById('dot' + i);
    if (dot) {
      dot.className = 'pin-dot';
      if (i < enteredPin.length) {
        dot.classList.add('filled');
      }
    }
  }
}

function showChangePinModal() {
  const modal = document.getElementById('changePinModal');
  if (modal) modal.style.display = 'flex';
}

function saveNewPin() {
  const input = document.getElementById('newPinInput');
  const val = input.value.trim();
  if (val.length !== 4) {
    showToast('PIN must be exactly 4 digits! 🔐');
    return;
  }
  localStorage.setItem('li_parent_pin', val);
  showToast('PIN updated successfully! 🔐');
  input.value = '';
  document.getElementById('changePinModal').style.display = 'none';
}
</script>
