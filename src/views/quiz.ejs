<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz: <%= quiz.title %> — LittleInvestors</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" type="image/x-icon" href="/img/penny_logo.png">
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script src="/js/pendo-init.js"></script>
  <script src="/js/stellar-helper.js"></script>
</head>
<body>

<div id="header" style="border-bottom:1px solid #f1f5f9">
  <a href="/courses" style="display:flex;align-items:center;gap:8px;text-decoration:none;padding:0 20px">
    <span style="font-size:22px;color:#64748b">‹</span>
    <span style="font-size:15px;font-weight:700;color:#1a2332">📝 <%= quiz.title %></span>
  </a>
</div>

<div class="quiz-wrap">
  <div class="quiz-progress-bar"><div class="quiz-progress-fill" id="quizFill" style="width:0%"></div></div>

  <div id="quizContainer">
    <div class="xp-badge">⭐ +50 XP per correct answer · 🪙 +5 Coins</div>
    <div class="quiz-q" id="quizQ"></div>
    <div class="quiz-options" id="quizOpts"></div>
    <div class="quiz-feedback" id="quizFeedback"></div>
    <button class="quiz-next-btn" id="nextBtn" onclick="nextQuestion()">Next Question →</button>
  </div>

  <div id="quizResult" style="display:none;text-align:center;padding-top:20px">
    <div style="font-size:72px;margin-bottom:16px" id="resultEmoji">🎉</div>
    <h2 style="font-size:26px;font-weight:900;color:#1a2332;margin-bottom:8px" id="resultTitle">Quiz Complete!</h2>
    <p style="color:#64748b;margin-bottom:24px" id="resultText"></p>
    <div style="background:linear-gradient(135deg,#ecfdf5,#d1fae5);border-radius:20px;padding:24px;margin-bottom:24px;border:1px solid #bbf7d0">
      <div style="font-size:42px;font-weight:900;color:#2AA46A" id="resultXP">+150 XP</div>
      <div style="font-size:13px;color:#166534;margin-top:4px">earned this quiz!</div>
      <div style="font-size:20px;font-weight:700;color:#F9A61B;margin-top:8px" id="resultCoins">+15 🪙</div>
    </div>

    <!-- Web3 On-chain claim block -->
    <div id="web3ClaimBlock" style="display:none; background:#0f172a; border-radius:20px; padding:20px; margin-bottom:24px; color:#fff; text-align:center;">
      <div style="font-weight:800; font-size:14px; color:#38bdf8; margin-bottom:8px;">⛓️ Web3 On-Chain Reward Available!</div>
      <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4; margin-bottom:14px;">
        Your parent has initialized your allowance vault! You can claim <span id="rewardXLMAmount" style="color:#ffd700; font-weight:700;">15</span> Testnet XLM directly to your wallet address.
      </p>
      <button id="claimRewardBtn" onclick="triggerClaim()" style="width:100%; padding:12px; background:#2AA46A; color:#fff; border:none; border-radius:12px; font-weight:700; font-size:14px; cursor:pointer;">
        Claim Reward on Stellar Blockchain 🚀
      </button>
      <div id="txDetails" style="display:none; margin-top:12px; font-size:11px; text-align:left; background:rgba(255,255,255,0.06); padding:10px; border-radius:8px;">
        <div style="color:#2aa46a; font-weight:700; margin-bottom:4px;">✅ Transaction Confirmed!</div>
        <div style="text-overflow:ellipsis; overflow:hidden; white-space:nowrap; font-family:monospace; color:rgba(255,255,255,0.7);">Tx Hash: <span id="txHashSpan"></span></div>
        <a id="txExplorerLink" href="#" target="_blank" style="color:#38bdf8; text-decoration:underline; display:block; margin-top:4px; font-weight:600;">View on Stellar Explorer 🔍</a>
      </div>
    </div>

    <a href="/courses" style="display:block;padding:16px;background:linear-gradient(135deg,#2AA46A,#1b7a4e);color:#fff;border-radius:16px;font-weight:700;font-size:16px;text-decoration:none;margin-bottom:12px">← Back to Lessons 📚</a>
    <a href="/home" style="display:block;padding:14px;background:#f1f5f9;color:#1a2332;border-radius:16px;font-weight:600;font-size:15px;text-decoration:none">Go to Dashboard 🏠</a>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const quizData = <%- JSON.stringify(quiz.questions) %>;
const lessonId = <%= lessonId %>;
let current = 0, score = 0, answered = false;

function renderQuestion() {
  const q = quizData[current];
  const pct = (current / quizData.length) * 100;
  document.getElementById('quizFill').style.width = pct + '%';
  document.getElementById('quizQ').textContent = 'Q' + (current+1) + '. ' + q.q;
  const opts = document.getElementById('quizOpts');
  opts.innerHTML = '';
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option';
    btn.textContent = opt;
    btn.onclick = () => selectAnswer(i, q.correct, q.explanation);
    opts.appendChild(btn);
  });
  document.getElementById('quizFeedback').className = 'quiz-feedback';
  document.getElementById('nextBtn').className = 'quiz-next-btn';
  answered = false;
}

function selectAnswer(i, correct, explanation) {
  if (answered) return;
  answered = true;
  const opts = document.querySelectorAll('.quiz-option');
  opts[i].classList.add(i === correct ? 'correct' : 'wrong');
  if (i !== correct) opts[correct].classList.add('correct');
  const isRight = i === correct;
  
  if (typeof pendo !== 'undefined') {
    pendo.track('quiz_answer_submitted', {
      lessonId: lessonId,
      questionIndex: current,
      isCorrect: isRight
    });
  }

  if (isRight) score++;
  const fb = document.getElementById('quizFeedback');
  fb.textContent = (isRight ? '✅ Correct! ' : '❌ Not quite. ') + explanation;
  fb.className = 'quiz-feedback show ' + (isRight ? 'good' : 'bad');
  document.getElementById('nextBtn').className = 'quiz-next-btn show';
}

function nextQuestion() {
  current++;
  if (current >= quizData.length) showResult();
  else renderQuestion();
}

function showResult() {
  document.getElementById('quizContainer').style.display = 'none';
  document.getElementById('quizFill').style.width = '100%';
  const xp = score * 50;
  const coins = score * 5;
  document.getElementById('quizResult').style.display = 'block';
  document.getElementById('resultEmoji').textContent = score === quizData.length ? '🏆' : score >= 2 ? '🎉' : '💪';
  document.getElementById('resultTitle').textContent = score === quizData.length ? 'Perfect Score!' : 'Quiz Complete!';
  document.getElementById('resultText').textContent = 'You got ' + score + ' out of ' + quizData.length + ' correct!';
  document.getElementById('resultXP').textContent = '+' + xp + ' XP';
  document.getElementById('resultCoins').textContent = '+' + coins + ' 🪙';
  
  // Save to localStorage
  const prevXP = parseInt(localStorage.getItem('li_xp') || '0');
  localStorage.setItem('li_xp', prevXP + xp);
  localStorage.setItem('li_level', Math.floor((prevXP + xp) / 200));
  const prevCoins = parseInt(localStorage.getItem('li_coins') || '800');
  localStorage.setItem('li_coins', prevCoins + coins);
  const qDone = parseInt(localStorage.getItem('li_quizzes_done') || '0') + 1;
  localStorage.setItem('li_quizzes_done', qDone);
  if (score === quizData.length) {
    localStorage.setItem('li_ach_perfect_quiz', '1');
    localStorage.setItem('li_ach_first_quiz', '1');
  }
  if (qDone >= 1) localStorage.setItem('li_ach_first_quiz', '1');

  if (typeof confetti !== 'undefined') {
    if (score === quizData.length) {
      confetti({particleCount:150,spread:100,origin:{y:0.5},colors:['#2AA46A','#F9A61B','#34d399','#fff']});
      setTimeout(() => confetti({particleCount:80,spread:130,origin:{y:0.4},angle:60}), 500);
      setTimeout(() => confetti({particleCount:80,spread:130,origin:{y:0.4},angle:120}), 700);
    } else if (score >= 2) {
      confetti({particleCount:60,spread:70,origin:{y:0.6},colors:['#2AA46A','#F9A61B']});
    }
  }
  
  // Handle Web3 claims
  const childAddress = localStorage.getItem('li_child_stellar_address');
  if (childAddress && coins > 0) {
    document.getElementById('web3ClaimBlock').style.display = 'block';
    document.getElementById('rewardXLMAmount').textContent = coins;
    window.earnedCoins = coins;
  }

  try { if(window.pendo) window.pendo.track('quiz_completed', {lessonId, score, total: quizData.length, xp}); } catch(e) {}
}

async function triggerClaim() {
  const childAddress = localStorage.getItem('li_child_stellar_address');
  if (!childAddress) return;
  const btn = document.getElementById('claimRewardBtn');
  btn.disabled = true;
  btn.style.opacity = '0.5';
  btn.textContent = 'Processing transaction... ⏳';
  
  try {
    const res = await StellarHelper.sendQuizReward(childAddress, window.earnedCoins || 5);
    if (res.success) {
      btn.style.display = 'none';
      document.getElementById('txDetails').style.display = 'block';
      document.getElementById('txHashSpan').textContent = res.hash;
      document.getElementById('txExplorerLink').href = `https://stellar.expert/explorer/testnet/tx/${res.hash}`;
      
      const coinsToClaim = window.earnedCoins || 5;
      
      // Also update contract vault savings pool on-chain if contract is deployed
      const contractId = localStorage.getItem('li_contract_id');
      if (contractId) {
        try {
          await StellarHelper.vaultSave(contractId, coinsToClaim);
        } catch (e) {
          console.error("Failed to update vault contract saved pool:", e);
        }
      }
      
      // Update balance local storage and play confetti
      const currentCoins = parseFloat(localStorage.getItem('li_coins') || '800');
      localStorage.setItem('li_coins', currentCoins + coinsToClaim);
      
      if (typeof confetti !== 'undefined') {
        confetti({particleCount:100,spread:80,origin:{y:0.6}});
      }
      showToast('Reward claimed successfully on-chain! 🎉');
    } else {
      throw new Error(res.error || 'Failed to submit reward.');
    }
  } catch(e) {
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.textContent = 'Claim Reward on Stellar Blockchain 🚀';
    showToast('Error: ' + e.message);
  }
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

renderQuestion();
</script>
</body>
</html>
